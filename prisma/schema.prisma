generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// NÚCLEO SAAS (Configuración Global)
// ==========================================

model planes {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String  @unique @db.VarChar(255)
  descripcion   String?
  precioMensual Decimal @default(0) @db.Decimal(10, 2)
  maxSucursales Int     @default(1)
  maxUsuarios   Int     @default(3)
  activo        Boolean @default(true)

  empresas Empresa[]

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
}

model Empresa {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre            String    @db.VarChar(255) // Razón Social o nombre del dueño
  rut               String?   @unique @db.VarChar(20)
  suscripcionActiva Boolean   @default(true)
  fechaVencimiento  DateTime? @db.Timestamptz(6)

  plan_id String? @db.Uuid
  plan    planes? @relation(fields: [plan_id], references: [id])

  sucursales Sucursal[]
  usuarios   usuarios[]

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
}

model Sucursal {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre    String   @db.VarChar(255) // Ej: "Gostinho - Putú"
  direccion String?  @db.VarChar(255)
  activo    Boolean? @default(true)

  empresa_id String  @db.Uuid
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  // Todo lo operativo ahora depende de la Sucursal específica
  usuarios   usuarios[]
  clientes   clientes[]
  productos  Productos[]
  categorias categoria[]
  opciones   opcions[]
  ordenes    ordenes[]

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
}

// ==========================================
// GESTIÓN DE ACCESO
// ==========================================

model usuarios {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre   String   @unique @db.VarChar(255)
  email    String?  @unique @db.VarChar(255)
  password String   @db.VarChar(255)
  rol      String?  @default("Cajero") @db.VarChar(255) // ADMIN_SISTEMA, ADMIN_LOCAL, GERENTE, CAJERO
  activo   Boolean? @default(true)

  empresa_id String?  @db.Uuid
  empresa    Empresa? @relation(fields: [empresa_id], references: [id])

  sucursal_id String?   @db.Uuid
  sucursal    Sucursal? @relation(fields: [sucursal_id], references: [id])

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
}

// ==========================================
// OPERACIÓN COMERCIAL (Vinculada a Sucursal)
// ==========================================

model clientes {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String  @db.VarChar(255)
  telefono       String? @db.VarChar(50)
  puntos_lealtad Int?    @default(0)

  sucursal_id String?   @db.Uuid
  sucursal    Sucursal? @relation(fields: [sucursal_id], references: [id])

  @@unique([telefono, sucursal_id])
}

model Productos {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String   @db.VarChar(255)
  descripcion String?
  imagen      String?  @db.VarChar(255)
  activo      Boolean? @default(true)
  CategoriaId String?  @db.Uuid

  sucursal_id String?   @db.Uuid
  sucursal    Sucursal? @relation(fields: [sucursal_id], references: [id])

  categoria       categoria?        @relation(fields: [CategoriaId], references: [id])
  variantes       variantes[]
  promocion_hijo  promocion_items[] @relation("prod_hijo")
  promocion_padre promocion_items[] @relation("prod_padre")

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
}

model categoria {
  id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre String   @db.VarChar(255)
  orden  Int?     @default(10)
  activa Boolean? @default(true)

  sucursal_id String?   @db.Uuid
  sucursal    Sucursal? @relation(fields: [sucursal_id], references: [id])

  Productos  Productos[]
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  updated_at DateTime    @updatedAt @db.Timestamptz(6)
}

model opcions {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre       String   @db.VarChar(255)
  precio_extra Int?     @default(0)
  stock        Boolean? @default(true)
  tipo         String   @default("topping") @db.VarChar(255)

  sucursal_id String?   @db.Uuid
  sucursal    Sucursal? @relation(fields: [sucursal_id], references: [id])

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
}

model ordenes {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folio       Int
  cliente     String? @default("Público General") @db.VarChar(255)
  total       Int?    @default(0)
  metodo_pago String? @default("EFECTIVO") @db.VarChar(255)
  estado      String? @default("PAGADO") @db.VarChar(255)

  sucursal_id String?   @db.Uuid
  sucursal    Sucursal? @relation(fields: [sucursal_id], references: [id])

  detalle_ordenes detalle_ordenes[]
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @updatedAt @db.Timestamptz(6)
}

// ==========================================
// MODELOS DE DETALLE (Sin cambios estructurales)
// ==========================================

model variantes {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String            @db.VarChar(255)
  precio          Int               @default(0)
  stock           Boolean?          @default(true)
  producto_id     String?           @db.Uuid
  Productos       Productos?        @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  promocion_items promocion_items[]
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @updatedAt @db.Timestamptz(6)
}

model detalle_ordenes {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre_producto   String   @db.VarChar(255)
  cantidad          Int
  precio_unitario   Int
  subtotal          Int
  opciones_elegidas Json?    @db.Json
  OrdenId           String?  @db.Uuid
  ordenes           ordenes? @relation(fields: [OrdenId], references: [id], onDelete: Cascade)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)
}

model promocion_items {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cantidad          Int?       @default(1)
  producto_padre_id String?    @db.Uuid
  producto_hijo_id  String?    @db.Uuid
  variante_hijo_id  String?    @db.Uuid
  prod_hijo         Productos? @relation("prod_hijo", fields: [producto_hijo_id], references: [id])
  prod_padre        Productos? @relation("prod_padre", fields: [producto_padre_id], references: [id], onDelete: Cascade)
  variantes         variantes? @relation(fields: [variante_hijo_id], references: [id])
}
